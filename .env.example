# =====================================================================
# Default LLM: local Ollama (gemma4:26b)
# =====================================================================
# The crew builds a shared crewai.LLM from these values and hands it to
# every Agent (including the hierarchical manager).

LLM_PROVIDER=ollama
MODEL=ollama/gemma4:26b
OLLAMA_API_BASE=http://127.0.0.1:11434

# =====================================================================
# Optional NVIDIA NIM profile
# =====================================================================
# To run against NVIDIA NIM instead, set:
#
#   LLM_PROVIDER=nvidia
#   NVIDIA_API_KEY=nvapi-REPLACE_ME
#   NVIDIA_MODEL_NAME=minimaxai/minimax-m2.7
#   NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# =====================================================================
# Embeddings (shared across all crew modes)
# =====================================================================
# sentence-transformers device for BAAI/bge-small-en-v1.5 (cpu | cuda).
CREW_EMBEDDING_DEVICE=cpu

# Offline toggles for the HF cache (recommended when DNS is flaky).
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1

# =====================================================================
# Optional tools
# =====================================================================
# Serper web search enables the ``web_researcher`` agent (Pattern 2 / 3).
# Leave unset to run the crew without internet tooling.
# SERPER_API_KEY=

# Placeholder: some crewai-tools versions validate OPENAI_API_KEY at
# import time. When LLM_PROVIDER=nvidia, crew.py replaces this value
# with NVIDIA_API_KEY at runtime so LiteLLM can use the OpenAI-compat
# code path against NVIDIA_API_BASE.
OPENAI_API_KEY=NA
